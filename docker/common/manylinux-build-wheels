#!/bin/bash
set -e

export LD_LIBRARY_PATH="/usr/local/lib64:/usr/local/lib"  # For whatever reason, this has to be set manually

# Activate the highest available gcc-toolset so pip's isolated build environment
# inherits the correct compiler (pip does not inherit SCL-activated PATH)
TOOLSET_ENABLE=$(ls /opt/rh/gcc-toolset-*/enable 2>/dev/null | sort -V | tail -1)
[ -n "${TOOLSET_ENABLE}" ] && source "${TOOLSET_ENABLE}"

SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
. "${SCRIPT_DIR}/dependency_versions"

# Allow overriding the Python versions to build for
if [ -n "${PYBIN_VERSIONS}" ]; then
  PYBIN_SUPPORTED_VERSIONS="${PYBIN_VERSIONS}"
fi

CODE_DIR="${1:-$(pwd)}"

# Log python versions
echo "Found the following Python versions:"
for PYBIN in /opt/python/*/bin; do
  PY_DIR=$(cut -d / -f 4 <<< "${PYBIN}")
  if [[ " ${PYBIN_SUPPORTED_VERSIONS} " == *" ${PY_DIR} "* ]]; then
    echo "${PY_DIR}"
  fi
done

# Build python wheels
WHEELS_DIR="$(pwd)/wheels"
mkdir -p "${WHEELS_DIR}"
mkdir -p dist
mkdir -p dist_full

# Share core library between builds, clean up after
FRANKY_LIB_CACHE_DIR=$(mktemp -d)
export FRANKY_LIB_CACHE_DIR
trap 'rm -rf "${FRANKY_LIB_CACHE_DIR}"' EXIT

# Compile wheels
echo "Building wheels..."
for PYBIN in /opt/python/*/bin; do
  PY_DIR=$(cut -d / -f 4 <<< "${PYBIN}")
  if [[ " ${PYBIN_SUPPORTED_VERSIONS} " == *" ${PY_DIR} "* ]]; then
    echo "Started building wheels for ${PYBIN}" &&
    "${PYBIN}/pip" wheel "$CODE_DIR" -w "${WHEELS_DIR}" 1> /dev/null &&
    echo "Successfully built wheel for ${PYBIN}"
  fi
done

echo "Finished building wheels."

# Bundle external shared libraries into the wheels
for whl in wheels/*.whl; do
  if [[ "$whl" =~ wheels/franky_control-.*\.whl ]]; then
    auditwheel repair "$whl" -w dist_full/
  else
    cp "$whl" dist_full/
  fi
done

# Install packages and test
for PYBIN in /opt/python/*/bin/; do
  PY_DIR=$(cut -d / -f 4 <<< "${PYBIN}")
  if [[ " ${PYBIN_SUPPORTED_VERSIONS} " == *" ${PY_DIR} "* ]]; then
    PY_DIR=$(basename "$(dirname "$PYBIN")")
    venv_dir=".venv_${PY_DIR}"
    "${PYBIN}/python" -m venv "${venv_dir}"
    source "${venv_dir}/bin/activate"
    pip install dist_full/franky_control-*-${PY_DIR}-*.whl
  fi
done

cp dist_full/franky_control-*.whl dist/
echo "Built the following wheels:"
ls dist
